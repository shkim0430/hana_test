<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#070A12"/>
      <stop offset="0.5" stop-color="#7C3AED"/>
      <stop offset="1" stop-color="#22D3EE"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="70" y="90" width="310" height="40" rx="20" fill="rgba(7,10,18,0.85)" stroke="#A5B4FC" stroke-width="1.5"/>
  <text x="90" y="118" fill="#E5E7EB" font-family="Inter, system-ui, -apple-system, Segoe UI, sans-serif" font-size="18" font-weight="600">
    AI-powered repayment strategy
  </text>
  <text x="70" y="240" fill="#F9FAFB" font-family="Inter, system-ui, -apple-system, Segoe UI, sans-serif"
        font-size="70" font-weight="800">
    RepayFirst AI
  </text>
  <text x="70" y="310" fill="#E5E7EB" font-family="Inter, system-ui, -apple-system, Segoe UI, sans-serif"
        font-size="30" font-weight="500">
    Make borrowers repay your loan first
  </text>
  <text x="70" y="360" fill="#D1D5DB" font-family="Inter, system-ui, -apple-system, Segoe UI, sans-serif"
        font-size="24" font-weight="400">
    AI repayment priority strategy for banks, card companies, and financial institutions
  </text>
  <rect x="70" y="400" width="410" height="56" rx="28" fill="rgba(15,23,42,0.9)" stroke="#A5B4FC" stroke-width="1.2"/>
  <text x="95" y="435" fill="#E5E7EB" font-family="Inter, system-ui, -apple-system, Segoe UI, sans-serif"
        font-size="22" font-weight="600">
    Analyze multi-debt repayment order with AI
  </text>
</svg>

